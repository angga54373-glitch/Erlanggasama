<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Erlangga Fauzan · CV & portfolio (English)</title>
    <!-- Font Awesome 5 (professional icons) -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css">
    <!-- Google Font: Inter + fallback -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f1f4f8;
            font-family: "Inter", system-ui, -apple-system, sans-serif;
            line-height: 1.5;
            color: #1e293b;
            padding: 2rem 1.5rem;
            display: flex;
            justify-content: center;
        }

        .portfolio-wrapper {
            max-width: 1100px;
            width: 100%;
        }

        /* main card */
        .paper {
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
            overflow: hidden;
            transition: all 0.2s ease;
        }

        /* header area with name/title and subtle wave */
        .header-bg {
            background: linear-gradient(145deg, #0b2b40 0%, #1a4b6b 100%);
            padding: 2.5rem 2.5rem 1.8rem 2.5rem;
            color: white;
        }

        .name-title h1 {
            font-size: 3rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .name-title .sub {
            font-size: 1.2rem;
            font-weight: 400;
            opacity: 0.85;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 0.3rem;
        }

        .sub i {
            font-size: 1rem;
            background: rgba(255,255,255,0.2);
            padding: 0.25rem 0.8rem;
            border-radius: 30px;
            font-style: normal;
        }

        .header-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 1.8rem;
        }

        .badge-row {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .chip {
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(4px);
            padding: 0.5rem 1.2rem;
            border-radius: 60px;
            font-size: 0.95rem;
            border: 1px solid rgba(255,255,255,0.2);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        /* main two column layout */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 2.1fr;
            gap: 0;
            background: #fff;
        }

        /* left panel — profile, contact, hobbies, skills */
        .left-panel {
            background: #f9fcff;
            padding: 2.2rem 1.8rem;
            border-right: 1px solid #e6edf4;
        }

        .right-panel {
            padding: 2.2rem 2.2rem 2.2rem 2rem;
            background: white;
        }

        /* profile summary */
        .profil-ringkas {
            background: white;
            border-radius: 24px;
            padding: 1.5rem 1.3rem;
            box-shadow: 0 6px 14px rgba(0, 27, 45, 0.04);
            margin-bottom: 2rem;
            border: 1px solid #e9f0f6;
        }

        .profil-ringkas h2 {
            font-size: 1.3rem;
            font-weight: 600;
            letter-spacing: -0.01em;
            color: #0b2b40;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .profil-ringkas h2 i {
            color: #1e6f9f;
        }

        .quote {
            font-size: 1rem;
            color: #2f4358;
            margin-bottom: 1.2rem;
            padding-left: 0.5rem;
            border-left: 4px solid #1e6f9f;
            padding-left: 1rem;
        }

        .pendidikan-item {
            display: flex;
            gap: 0.8rem;
            margin: 1rem 0 0.5rem 0;
        }

        .pendidikan-item .icon {
            background: #e1ecf5;
            width: 44px;
            height: 44px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1e6f9f;
            font-size: 1.3rem;
        }

        .pendidikan-detail h3 {
            font-weight: 600;
            font-size: 1.1rem;
        }

        .pendidikan-detail .meta {
            color: #547087;
            font-size: 0.9rem;
        }

        /* contact & personal */
        .contact-box {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 6px 14px rgba(0, 27, 45, 0.02);
            border: 1px solid #e9f0f6;
            margin-bottom: 2rem;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.1rem;
            font-size: 0.95rem;
            word-break: break-word;
        }

        .contact-item i {
            width: 24px;
            color: #1e6f9f;
            font-size: 1.2rem;
            text-align: center;
        }

        .contact-item a, .contact-item span {
            color: #1e293b;
            text-decoration: none;
            border-bottom: 1px dotted transparent;
            transition: 0.2s;
        }

        .contact-item a:hover {
            border-bottom: 1px dotted #1e6f9f;
            color: #0b2b40;
        }

        .website-link {
            background: #eef5fa;
            padding: 0.4rem 1rem;
            border-radius: 40px;
            font-size: 0.9rem;
            display: inline-block;
            margin-top: 0.2rem;
        }

        /* skill chips & languages */
        .skill-section {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            box-shadow: 0 6px 14px rgba(0, 27, 45, 0.02);
            border: 1px solid #e9f0f6;
            margin-bottom: 2rem;
        }

        .skill-section h3 {
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 1rem;
            color: #0b2b40;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .skill-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin-bottom: 1.5rem;
        }

        .skill-tag {
            background: #e5f0fa;
            color: #114a66;
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: 450;
            border: 1px solid #cde0ed;
        }

        .skill-tag.learning {
            background: #fff3d6;
            color: #8a6300;
            border-color: #f7e2b5;
        }

        .lang-item {
            display: flex;
            justify-content: space-between;
            border-bottom: 1px dashed #cbdae6;
            padding: 0.5rem 0;
        }

        .lang-item span:first-child {
            font-weight: 500;
        }

        .lang-item span:last-child {
            color: #4f6c84;
            font-style: italic;
            font-size: 0.9rem;
        }

        /* hobbies / interests */
        .hobby-wrap {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            border: 1px solid #e9f0f6;
        }

        .hobby-icons {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem 1.8rem;
            margin-top: 0.8rem;
        }

        .hobby-icons span {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #f0f7fd;
            padding: 0.4rem 1rem;
            border-radius: 40px;
            font-size: 0.95rem;
        }

        /* right panel : experience */
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0b2b40;
            letter-spacing: -0.01em;
            border-bottom: 2px solid #e4edf5;
            padding-bottom: 0.3rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-title i {
            color: #1e6f9f;
        }

        .exp-card {
            margin-bottom: 2.2rem;
        }

        .exp-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.2rem;
        }

        .exp-header h3 {
            font-weight: 700;
            font-size: 1.2rem;
            color: #0d3c54;
        }

        .exp-date {
            background: #e3eef8;
            padding: 0.2rem 0.9rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #1d5679;
        }

        .exp-sub {
            font-weight: 500;
            color: #2e5775;
            margin-bottom: 0.3rem;
            font-size: 0.98rem;
        }

        .exp-desc {
            color: #2f4052;
            font-size: 0.95rem;
            margin-left: 0.2rem;
            padding-left: 0.7rem;
            border-left: 3px solid #bdd8ec;
            margin-top: 0.3rem;
            margin-bottom: 0.8rem;
        }

        .exp-detail-list {
            list-style: none;
            margin-top: 0.4rem;
        }

        .exp-detail-list li {
            margin-bottom: 0.5rem;
            display: flex;
            gap: 0.7rem;
            align-items: flex-start;
            font-size: 0.95rem;
        }

        .exp-detail-list li i {
            color: #1e6f9f;
            font-size: 0.8rem;
            margin-top: 0.2rem;
            min-width: 16px;
        }

        .divider-light {
            height: 1px;
            background: linear-gradient(to right, #dbe8f2, transparent);
            margin: 1rem 0 1.5rem 0;
        }

        /* sales / footer note */
        .sales-highlight {
            background: #f1f8ff;
            border-radius: 20px;
            padding: 1.5rem;
            margin-top: 2rem;
            border: 1px solid #cde0ed;
        }

        .sales-highlight p {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .sales-highlight i {
            font-size: 1.5rem;
            color: #1e6f9f;
        }

        /* responsive */
        @media (max-width: 800px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
            .left-panel {
                border-right: none;
                border-bottom: 1px solid #e6edf4;
            }
            .header-bg {
                padding: 1.8rem;
            }
            .name-title h1 {
                font-size: 2.4rem;
            }
        }

        @media (max-width: 450px) {
            .header-grid {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.8rem;
            }
        }
    </style>
</head>
<body>
